{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Redstring",
  "colors": {
    "primary": "#DC2626",
    "light": "#EF4444",
    "dark": "#991B1B"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "architecture",
              "development"
            ]
          },
          {
            "group": "Core Concepts",
            "pages": [
              "concepts/nodes-and-graphs",
              "concepts/prototype-instance-model",
              "concepts/semantic-web-integration"
            ]
          },
          {
            "group": "Components",
            "pages": [
              "components/node-canvas",
              "components/pie-menu",
              "components/panel",
              "components/semantic-editor"
            ]
          },
          {
            "group": "Data & State",
            "pages": [
              "data/graph-store",
              "data/universe-manager",
              "data/file-formats"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Core Classes",
            "pages": [
              "api/graph",
              "api/node",
              "api/edge"
            ]
          },
          {
            "group": "Services",
            "pages": [
              "api/sparql-client",
              "api/knowledge-federation",
              "api/persistent-auth"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/redstring-project",
          "icon": "github"
        },
        {
          "anchor": "Demo",
          "href": "https://redstring-demo.com",
          "icon": "play"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/redstring-project"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try Demo",
      "href": "https://redstring-demo.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/redstring-project"
    }
  }
}
